# Google Service Account key as base64-encoded JSON string
# To encode: base64 -w 0 service-account.json  (Linux/Mac)
# On Windows PowerShell: [Convert]::ToBase64String([System.IO.File]::ReadAllBytes("service-account.json"))
GOOGLE_SERVICE_ACCOUNT_KEY=<base64-encoded service account JSON>

# Google Sheets ID (from the URL of your spreadsheet)
GOOGLE_SHEET_ID=1N1POd9dhcXy3f-u_UZggNsLzE3hlObK4Y7JzFJQANQI

# Google Drive folder ID containing audio files
GOOGLE_DRIVE_FOLDER_ID=19tfSEeBaOchNwSB2VNZd9s9PmEpDAIkG

# JWT secret — change this to a long random string in production
JWT_SECRET=change-me-in-production

# Port to run the server on
PORT=3001

# Path to the CSV data file (relative to the server directory)
CSV_PATH=../EGRA_EGMA_Combine_WIDE.csv

# USERS: JSON array of user objects with bcrypt password hashes
# Generate a hash: node -e "const b=require('bcryptjs');b.hash('yourpassword',10).then(h=>console.log(h))"
# Example below uses placeholder hashes — replace with real bcrypt hashes before deploying
USERS=[{"username":"mpatel","passwordHash":"$2a$10$placeholder"},{"username":"ahwaz","passwordHash":"$2a$10$placeholder"}]
